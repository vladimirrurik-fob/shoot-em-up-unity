# This .gitignore file should be placed at the root of your Unity project directory
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore

# ======================
# Unity generated folders
# ======================
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]serSettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/
/[Ss]creenshots/

# ======================
# IDE / editor caches
# ======================
.vs/
.idea/
.vscode/
.gradle/
.consulo/
ExportedObj/

# Autogenerated JetBrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Uncomment to ignore the Asset Store tools plugin
# /[Aa]ssets/AssetStoreTools*

# ======================
# Autogenerated solution / project files
# ======================
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files for the above
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Mono crash dumps
mono_crash.*.json

# Crashlytics
crashlytics-build.properties

# SBM commodity cache
SBMCommodityCache/

# ======================
# Builds / export artifacts
# ======================
*.apk
*.aab
*.unitypackage
*.app
*.tgz

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]tandaloneAssets/
/[Aa]ssets/[Pp]lugins/[Aa]ndroid/[Ff]acebookSDK/lint-cache-from-maven.xml

# ======================
# OS files
# ======================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
